VCoreMongoRequests
| where TimeGenerated > ago(24h)
| where OperationName in ("update","findAndModify","bulkWrite","replace")
| extend Cmd = tostring(PiiCommandText)
| extend ObjectId = extract(@"ObjectId\(\""([0-9a-fA-F]{24})\""\)", 1, Cmd)
| extend UpdateSection =
    iif(Cmd has "$set" or Cmd has "$unset" or Cmd has "$inc" or Cmd has "$push" or Cmd has "$pull",
        Cmd,
        "")
| project TimeGenerated,
          OperationName,
          DatabaseName,
          CollectionName,
          UserId,
          ClientIp,
          UserAgent,
          ObjectId,
          UpdateSection
| order by TimeGenerated desc
